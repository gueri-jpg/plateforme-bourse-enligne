# ============================================================
# Modele de configuration - Backend FastAPI (Module Admin)
# Copier ce fichier en backend/.env et renseigner les valeurs
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bourse_db
POSTGRES_USER=bourse_admin
POSTGRES_PASSWORD=CHANGER_MOI

# --- Keycloak ---
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=bourse-en-ligne
KEYCLOAK_BACKEND_CLIENT_ID=backend-api
KEYCLOAK_ADMIN_CLIENT_ID=admin-tools
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGER_MOI

# --- Roles ---
ROLE_ADMINISTRATEUR=administrateur
ROLE_INVESTISSEUR=investisseur

# --- Intégration SSO banque CFC (inter-service) ---
# URL API banque accessible depuis ce backend (server-to-server)
BANQUE_API_URL=http://localhost:8000
# URL frontend banque accessible depuis le navigateur de l'investisseur
BANQUE_FRONTEND_URL=http://cfc.127.0.0.1.nip.io
# Token partagé pour les appels inter-service
INTER_SERVICE_TOKEN=bourse-banque-inter-service-token-poc

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@cfassistance.org
RESEND_OVERRIDE_TO=
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=mobile-app
EXPO_PUBLIC_MARKET_OPEN_HOUR=9
EXPO_PUBLIC_MARKET_CLOSE_HOUR=15
EXPO_PUBLIC_MARKET_CLOSE_MIN=30

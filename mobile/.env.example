# ============================================================
# Modèle de configuration — App mobile Expo
# Copier en .env et ajuster les valeurs
# ============================================================

# ── DEV LOCAL ──────────────────────────────────────────────
# IP de la machine qui fait tourner Docker
# (obtenir via : ipconfig → Wi-Fi → Adresse IPv4)
# Ces variables sont ignorées si EXPO_PUBLIC_API_URL est défini.
EXPO_PUBLIC_BACKEND_IP=192.168.X.X
EXPO_PUBLIC_BACKEND_PORT=8000
EXPO_PUBLIC_KEYCLOAK_PORT=9090

# ── PRODUCTION (EAS build preview/production) ───────────────
# Décommenter et renseigner pour pointer vers les domaines Azure.
# Ces variables sont normalement injectées par eas.json (build.preview.env)
# et n'ont pas besoin d'être dans ce fichier pour les builds EAS.
#
# EXPO_PUBLIC_API_URL=https://api.bourse-enligne.ma
# EXPO_PUBLIC_KEYCLOAK_URL=https://auth.bourse-enligne.ma

# ── COMMUN ─────────────────────────────────────────────────
EXPO_PUBLIC_KEYCLOAK_REALM=bourse-en-ligne
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=mobile-app

# Horaires BVC (heure Casablanca, UTC+1) — Lundi–Vendredi 09:00–15:30
EXPO_PUBLIC_MARKET_OPEN_HOUR=9
EXPO_PUBLIC_MARKET_CLOSE_HOUR=15
EXPO_PUBLIC_MARKET_CLOSE_MIN=30

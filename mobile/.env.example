# ============================================================
# Modèle de configuration — App mobile Expo
# Copier en .env et ajuster les valeurs
# ============================================================

# IP de la machine qui fait tourner Docker
# (obtenir via : ipconfig → Wi-Fi → Adresse IPv4)
EXPO_PUBLIC_BACKEND_IP=192.168.X.X

# Ports des services (ne changent pas en général)
EXPO_PUBLIC_BACKEND_PORT=8000
EXPO_PUBLIC_KEYCLOAK_PORT=9090

# Keycloak
EXPO_PUBLIC_KEYCLOAK_REALM=bourse-en-ligne
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=mobile-app

# Horaires BVC (heure Casablanca, UTC+1)
# Lundi–Vendredi  09:00 – 15:30
EXPO_PUBLIC_MARKET_OPEN_HOUR=9
EXPO_PUBLIC_MARKET_CLOSE_HOUR=15
EXPO_PUBLIC_MARKET_CLOSE_MIN=30

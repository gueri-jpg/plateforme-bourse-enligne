# ============================================================
# Modele de configuration - Plateforme de Bourse en Ligne
# Copier ce fichier en .env et renseigner les valeurs reelles
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=bourse_admin
POSTGRES_PASSWORD=CHANGER_MOI
POSTGRES_DB=bourse_db

# --- Keycloak (admin console) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGER_MOI

# --- Keycloak (connexion a PostgreSQL) ---
KC_DB_USERNAME=bourse_admin
KC_DB_PASSWORD=CHANGER_MOI